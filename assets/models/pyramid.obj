vn 0.0 0.7 -0.7

# Base (2 triangles) - CCW from below (or CW from above, so we flip to make it CCW from below? No, we want CCW from outside)
# From below, 1-2-3 is CCW. 
f 1/1/1 3/3/1 2/2/1
f 1/1/1 4/4/1 3/3/1

# Sides - already CCW from outside
f 1/1/2 2/2/2 5/3/2
f 2/1/3 3/2/3 5/3/3
f 3/1/4 4/2/4 5/3/4
f 4/1/5 1/2/5 5/3/5
